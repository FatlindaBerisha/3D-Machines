    "terms": {
        "title": "Terms of Service",
        "lastUpdated": "Last updated: June 2025",
        "section1Title": "1. Acceptance of Terms",
        "section1Text": "By accessing and using the 3D Machines platform, you agree to comply with these Terms of Service. This platform allows you to manage your 3D printing jobs, monitor filament usage, and track printer status.",
        "section2Title": "2. User Responsibilities",
        "section2Text": "You agree to use the platform lawfully, ensuring that your print jobs do not infringe on intellectual property rights or contain illegal content.",
        "section3Title": "3. Account Security",
        "section3Text": "You are responsible for maintaining the confidentiality of your account credentials and for all activities that occur under your account.",
        "section4Title": "4. Service Availability",
        "section4Text": "We strive to keep the platform available 24/7 but do not guarantee uninterrupted service. Maintenance and updates may cause temporary downtime.",
        "section5Title": "5. Termination",
        "section5Text": "We reserve the right to suspend or terminate your account if you violate these terms or engage in misuse of the platform.",
        "section6Title": "6. Limitation of Liability",
        "section6Text": "3D Machines is not liable for any direct or indirect damages arising from your use of the platform or printing results.",
        "section7Title": "7. Changes to Terms",
        "section7Text": "We may update these Terms of Service at any time. Continued use after changes means you accept the new terms.",
        "section8Title": "8. Contact Us",
        "section8Text": "For questions about these terms, please contact"
    },
    "privacy": {
        "title": "Privacy Policy",
        "lastUpdated": "Last updated: June 2025",
        "section1Title": "1. Information We Collect",
        "section1Text": "We collect information you provide when registering or using the 3D Machines platform, such as your name, email, and printer usage data to optimize your experience and enhance service quality.",
        "section2Title": "2. How We Use Your Information",
        "section2Text": "Your data helps us provide and improve the service, manage your print jobs, monitor filament usage, and communicate important updates or support information.",
        "section3Title": "3. Data Security",
        "section3Text": "We use industry-standard security measures to protect your personal data from unauthorized access, disclosure, or destruction. Our systems are monitored to ensure continued protection.",
        "section4Title": "4. Sharing Your Information",
        "section4Text": "We do not sell your personal data. Information is only shared with trusted service providers when necessary to operate the platform or comply with legal obligations.",
        "section5Title": "5. Cookies and Analytics",
        "section5Text": "The platform may use cookies and analytics tools to improve performance, analyze traffic, and personalize your experience. You can control cookie settings in your browser.",
        "section6Title": "6. Your Rights",
        "section6Text": "You have the right to access, correct, or delete your personal data. To exercise these rights or request more details, contact us at the email address below.",
        "section7Title": "7. Changes to This Policy",
        "section7Text": "We may update this Privacy Policy periodically. Continued use of the platform after changes indicates your acceptance of the updated version.",
        "section8Title": "8. Contact Us",
        "section8Text": "For questions or concerns about this Privacy Policy, please contact"
    },
